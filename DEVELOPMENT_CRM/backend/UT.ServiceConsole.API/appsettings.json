{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=UT_ServiceConsole;Uid=root;Pwd=root;CharSet=utf8mb4;"
  },
  "JwtSettings": {
    "SecretKey": "UT_ServiceConsole_SuperSecret_Key_2026_MinLength32Chars!",
    "Issuer": "UT.ServiceConsole.API",
    "Audience": "UT.ServiceConsole.Client",
    "ExpirationMinutes": 480,
    "RefreshTokenExpirationDays": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/ut-service-console-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5173" ]
  }
}
